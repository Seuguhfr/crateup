{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrateUp",
  "version": "3.1.0",
  "identifier": "com.custom.crateup",
  "build": {
    "beforeDevCommand": "",
    "devUrl": null,
    "beforeBuildCommand": "",
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CrateUp",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https://tauri.localhost ipc:; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: tauri: https://tauri.localhost; media-src 'self' asset: tauri: https://tauri.localhost blob:; connect-src 'self' asset: tauri: https://tauri.localhost ipc: ws: http://localhost:*;",
      "dangerousDisableAssetCspModification": ["style-src"],
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "../node-sidecar/**/*",
      "binaries/ffmpeg*",
      "binaries/ffprobe*",
      "binaries/fpcalc*"
    ]
  }
}
